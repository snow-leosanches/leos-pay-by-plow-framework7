# Copy to `.env` and adjust. Vite loads `.env`, `.env.local`, `.env.[mode]`, `.env.[mode].local`.
# Only variables prefixed with VITE_ are exposed to browser code (import.meta.env).

# Snowplow collector URL — e.g. Snowplow Micro: http://localhost:9090
VITE_SNOWPLOW_COLLECTOR=http://localhost:9090

# App ID attached to Snowplow events
VITE_SNOWPLOW_APP_ID=leos-pay-by-plow
